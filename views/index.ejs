<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="7-2HS9mQWFoj3zHgpEAvBnVI8e3ylgoFpejMBkPGlhk" />
    
    <!-- SEO MODULE - DevCoreAI Optimized -->
    <title>DevCore Sound // Audio Intelligence Module</title>
    <meta name="description" content="Streaming dan scan frekuensi audio secara instan di negara Novle. Cari musik dan data audio lewat jaringan DevCoreAI.">
    <meta name="keywords" content="DevCore Sound, DevCoreAI, Music Scraper, Novle, XdpzQ, Audio Tracer">
    <meta name="author" content="XdpzQ">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph for Social Media -->
    <meta property="og:title" content="DevCore Sound | Audio Scanner">
    <meta property="og:description" content="Scanner audio otomatis untuk melacak jejak digital di Novle.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://your-app-name.vercel.app">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; color: #000000; overflow-x: hidden; }
        .thin-border { border: 1px solid #e5e5e5; }
        .search-input { border-bottom: 2px solid #000; transition: 0.3s; }
        .search-input:focus { border-color: #00cfcf; outline: none; }
        #player-bar { border-top: 1px solid #e5e5e5; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px); }
        .song-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
        .song-card:hover { background-color: #fafafa; transform: translateY(-4px); border-color: #000; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #000; }
        .loading-pulse { animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { opacity: 0.5; } 50% { opacity: 1; } 100% { opacity: 0.5; } }
    </style>
</head>
<body class="antialiased">

    <!-- Header / Navbar -->
    <nav class="p-6 flex justify-between items-center fixed top-0 w-full bg-white/80 backdrop-blur-md z-50 border-b border-gray-100">
        <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-cyan-500 rounded-full animate-ping"></div>
            <span class="font-black tracking-tighter text-xl">DEVCORE_SOUND</span>
        </div>
        <div class="text-[10px] font-mono text-gray-400 text-right leading-none">
            IP_TRACKER: ACTIVE<br>SCANNING_NOVLE: 100%
        </div>
    </nav>

    <main class="mt-32 max-w-6xl mx-auto px-6 mb-40">
        <!-- Search Section -->
        <section class="mb-16">
            <h1 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-none">CARI FREKUENSI AUDIO.</h1>
            <div class="flex flex-col md:flex-row gap-4">
                <input type="text" id="searchInput" placeholder="Input target artist/song..." 
                    class="w-full text-2xl font-light search-input bg-transparent py-4">
                <button onclick="performSearch()" class="bg-black text-white px-12 py-4 font-bold hover:bg-cyan-600 transition duration-300">
                    SCAN_DATABASE
                </button>
            </div>
        </section>

        <!-- Stats Bar -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="p-6 thin-border rounded-xl">
                <p class="text-xs font-bold uppercase text-gray-400 mb-2">Google Indexing</p>
                <p class="text-2xl font-black text-cyan-600">READY</p>
            </div>
            <div class="p-6 thin-border rounded-xl bg-black text-white">
                <p class="text-xs font-bold uppercase text-gray-500 mb-2">Novle Intel Access</p>
                <p class="text-2xl font-black italic">GRANTED</p>
            </div>
            <div class="p-6 thin-border rounded-xl">
                <p class="text-xs font-bold uppercase text-gray-400 mb-2">Total Matches</p>
                <p id="counter" class="text-2xl font-black">0</p>
            </div>
        </div>

        <!-- Results Area -->
        <div id="resultsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Data injected here -->
        </div>
    </main>

    <!-- Persistent Player Bar -->
    <div id="player-bar" class="fixed bottom-0 left-0 right-0 p-6 hidden z-50">
        <div class="max-w-6xl mx-auto flex items-center gap-6">
            <img id="player-thumb" src="" class="w-16 h-16 rounded object-cover shadow-xl border border-gray-200">
            <div class="flex-1 overflow-hidden">
                <p id="player-title" class="font-bold text-sm truncate uppercase tracking-widest">TITLE_LOADING</p>
                <p id="player-artist" class="text-xs text-gray-500 uppercase">ARTIST_UNKNOWN</p>
            </div>
            <div class="hidden md:block w-64 h-16 bg-black rounded-lg overflow-hidden relative">
                <!-- Iframe Youtube (Hidden but playing sound) -->
                <iframe id="main-player" width="100%" height="100%" src="" frameborder="0" allow="autoplay; encrypted-media"></iframe>
            </div>
            <button onclick="closePlayer()" class="text-[10px] font-black border-2 border-black px-6 py-2 hover:bg-black hover:text-white transition uppercase">Termination</button>
        </div>
    </div>

    <script>
        async function performSearch() {
            const query = document.getElementById('searchInput').value;
            const grid = document.getElementById('resultsGrid');
            const counter = document.getElementById('counter');
            
            if (!query) return;

            grid.innerHTML = `
                <div class="col-span-full py-20 text-center">
                    <p class="font-mono text-sm loading-pulse uppercase tracking-[0.5em]">Bypassing Firewalls & Scanning Waves...</p>
                </div>
            `;

            try {
                const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                const data = await response.json();

                grid.innerHTML = '';
                counter.innerText = data.length;

                if (data.length === 0) {
                    grid.innerHTML = '<p class="col-span-full text-center font-bold uppercase">No Frequency Found.</p>';
                    return;
                }

                data.forEach(song => {
                    const cleanTitle = song.title.replace(/['"`]/g, "");
                    const card = `
                        <div class="song-card p-5 rounded-2xl thin-border flex flex-col gap-4" 
                             onclick="playMusic('${song.videoId}', '${cleanTitle}', '${song.author.name}', '${song.thumbnail}')">
                            <div class="relative overflow-hidden rounded-xl h-48 bg-gray-100">
                                <img src="${song.thumbnail}" class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-700">
                            </div>
                            <div>
                                <h3 class="font-black text-sm uppercase truncate mb-1">${song.title}</h3>
                                <p class="text-[10px] font-bold text-cyan-600 tracking-tighter">${song.author.name} // ${song.timestamp}</p>
                            </div>
                        </div>
                    `;
                    grid.innerHTML += card;
                });
            } catch (err) {
                grid.innerHTML = '<p class="col-span-full text-center text-red-500 font-mono">CRITICAL_SYSTEM_ERROR: SEARCH_FAILED</p>';
            }
        }

        function playMusic(id, title, artist, thumb) {
            const playerBar = document.getElementById('player-bar');
            const iframe = document.getElementById('main-player');
            const titleDisplay = document.getElementById('player-title');
            const artistDisplay = document.getElementById('player-artist');
            const thumbDisplay = document.getElementById('player-thumb');
            
            // Fixed logic: Link embed youtube
            iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&modestbranding=1&rel=0`;
            titleDisplay.innerText = title;
            artistDisplay.innerText = artist;
            thumbDisplay.src = thumb;
            
            playerBar.classList.remove('hidden');
        }

        function closePlayer() {
            const playerBar = document.getElementById('player-bar');
            document.getElementById('main-player').src = "";
            playerBar.classList.add('hidden');
        }

        document.getElementById('searchInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') performSearch();
        });
    </script>
</body>
</html>
