<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCoreAI - Music Player</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0a0a0a; color: #e5e5e5; font-family: 'Courier New', Courier, monospace; }
        .card { background-color: #141414; border: 1px solid #222; transition: 0.3s; }
        .card:hover { border-color: #00cfcf; box-shadow: 0 0 10px #00cfcf33; }
        #player-bar { background: rgba(10, 10, 10, 0.95); border-top: 2px solid #00cfcf; backdrop-filter: blur(10px); }
    </style>
</head>
<body class="p-8 mb-32">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-cyan-500 mb-2 tracking-tighter">DevCoreAI // MUSIC_INJECTOR</h1>
        <p class="text-gray-500 mb-8 text-xs">LOG: Monitoring digital wave... [CONNECTED]</p>

        <!-- Search Form -->
        <form action="/search" method="GET" class="flex gap-2 mb-10">
            <input type="text" name="q" placeholder="Cari target audio..." value="<%= query %>" 
                class="w-full p-3 rounded bg-zinc-900 border border-zinc-800 focus:outline-none focus:border-cyan-500 text-white text-sm">
            <button type="submit" class="bg-cyan-700 hover:bg-cyan-600 px-6 py-3 rounded font-bold text-sm transition">SEARCH</button>
        </form>

        <% if (results) { %>
            <div class="grid gap-4">
                <% results.forEach(song => { %>
                    <div class="card p-4 rounded flex items-center gap-4">
                        <img src="<%= song.thumbnailUrl %>" alt="thumb" class="w-14 h-14 rounded grayscale hover:grayscale-0 transition">
                        <div class="flex-1">
                            <h3 class="font-bold text-white text-sm truncate"><%= song.title %></h3>
                            <p class="text-xs text-gray-500"><%= song.artists[0].name %></p>
                        </div>
                        <!-- Tombol Play memicu fungsi JavaScript -->
                        <button onclick="playMusic('<%= song.youtubeId %>', '<%= song.title.replace(/'/g, '') %>')" 
                            class="text-cyan-500 text-xs font-bold border border-cyan-900 px-4 py-2 rounded hover:bg-cyan-500 hover:text-black transition">
                            PLAY
                        </button>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    <!-- Floating Player Bar -->
    <div id="player-bar" class="fixed bottom-0 left-0 right-0 p-4 hidden">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-4">
            <div class="flex-1">
                <p id="now-playing" class="text-cyan-500 text-xs font-bold truncate">Now Playing: None</p>
            </div>
            <!-- Iframe YouTube (Hidden or Small) -->
            <div id="video-container" class="w-full md:w-64 h-32 md:h-20 bg-black rounded overflow-hidden">
                <iframe id="main-player" width="100%" height="100%" src="" 
                    frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen>
                </iframe>
            </div>
            <button onclick="closePlayer()" class="text-red-500 text-xs font-bold px-2">CLOSE</button>
        </div>
    </div>

    <script>
        function playMusic(id, title) {
            const playerBar = document.getElementById('player-bar');
            const iframe = document.getElementById('main-player');
            const titleDisplay = document.getElementById('now-playing');
            
            // Set source iframe ke mode embed + autoplay
            iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
            titleDisplay.innerText = `NOW_PLAYING: ${title}`;
            
            // Tampilkan player bar
            playerBar.classList.remove('hidden');
        }

        function closePlayer() {
            const playerBar = document.getElementById('player-bar');
            const iframe = document.getElementById('main-player');
            iframe.src = ""; // Stop music
            playerBar.classList.add('hidden');
        }
    </script>
</body>
</html>
