<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevCoreAI // AUDIO_MODULE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; color: #000000; overflow-x: hidden; }
        .thin-border { border: 1px solid #e5e5e5; }
        .search-input { border-bottom: 2px solid #000; transition: 0.3s; }
        .search-input:focus { border-color: #00cfcf; outline: none; }
        #player-bar { border-top: 1px solid #e5e5e5; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .song-card { transition: all 0.2s ease; cursor: pointer; }
        .song-card:hover { background-color: #f9f9f9; transform: translateY(-2px); }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #000; }
    </style>
</head>
<body class="antialiased">

    <!-- Header / Navbar -->
    <nav class="p-6 flex justify-between items-center fixed top-0 w-full bg-white z-50 border-b border-gray-100">
        <div class="flex items-center gap-2">
            <div class="w-3 h-3 bg-cyan-500 rounded-full animate-pulse"></div>
            <span class="font-black tracking-tighter text-xl">DEVCORE_AI</span>
        </div>
        <div class="text-[10px] font-mono text-gray-400 text-right leading-none">
            SYSTEM_STATUS: ACTIVE<br>NOVLE_INTEL: MONITORING
        </div>
    </nav>

    <main class="mt-32 max-w-6xl mx-auto px-6 mb-40">
        <!-- Search Section -->
        <section class="mb-16">
            <h1 class="text-6xl font-black mb-8 tracking-tighter leading-none">CARI FREKUENSI AUDIO.</h1>
            <div class="flex gap-4">
                <input type="text" id="searchInput" placeholder="Ketik judul lagu atau artis..." 
                    class="w-full text-2xl font-light search-input bg-transparent py-4">
                <button onclick="performSearch()" class="bg-black text-white px-10 py-4 font-bold hover:bg-cyan-500 transition duration-300">
                    SCAN
                </button>
            </div>
        </section>

        <!-- Stats / Elements Lain -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="p-6 thin-border rounded-xl">
                <p class="text-xs font-bold uppercase text-gray-400 mb-2">Signal Strength</p>
                <p class="text-2xl font-black">99.2%</p>
            </div>
            <div class="p-6 thin-border rounded-xl bg-black text-white">
                <p class="text-xs font-bold uppercase text-gray-500 mb-2">Novle Database</p>
                <p class="text-2xl font-black italic">ENCRYPTED</p>
            </div>
            <div class="p-6 thin-border rounded-xl">
                <p class="text-xs font-bold uppercase text-gray-400 mb-2">Total Scanned</p>
                <p id="counter" class="text-2xl font-black">0</p>
            </div>
        </div>

        <!-- Results Area -->
        <div id="resultsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Data bakal di-inject lewat JavaScript -->
        </div>
    </main>

    <!-- Persistent Player Bar (Background Play) -->
    <div id="player-bar" class="fixed bottom-0 left-0 right-0 p-6 hidden z-50">
        <div class="max-w-6xl mx-auto flex items-center gap-6">
            <img id="player-thumb" src="" class="w-16 h-16 rounded object-cover shadow-2xl">
            <div class="flex-1 overflow-hidden">
                <p id="player-title" class="font-bold text-sm truncate">Song Title</p>
                <p id="player-artist" class="text-xs text-gray-500">Artist Name</p>
            </div>
            <div class="hidden md:block w-48 h-12 bg-gray-100 rounded overflow-hidden">
                <iframe id="main-player" width="100%" height="100%" src="" frameborder="0" allow="autoplay"></iframe>
            </div>
            <button onclick="closePlayer()" class="text-xs font-black border-2 border-black px-4 py-2 hover:bg-black hover:text-white transition">STOP</button>
        </div>
    </div>

    <script>
        async function performSearch() {
            const query = document.getElementById('searchInput').value;
            const grid = document.getElementById('resultsGrid');
            const counter = document.getElementById('counter');
            
            if (!query) return;

            grid.innerHTML = '<p class="text-center col-span-full font-mono animate-pulse uppercase">Scanning digital waves...</p>';

            const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
            const data = await response.json();

            grid.innerHTML = '';
            counter.innerText = data.length;

            data.forEach(song => {
                const card = `
                    <div class="song-card p-4 rounded-2xl thin-border flex flex-col gap-4" onclick="playMusic('${song.videoId}', '${song.title.replace(/'/g, "")}', '${song.author.name}', '${song.thumbnail}')">
                        <img src="${song.thumbnail}" class="w-full h-48 object-cover rounded-xl filter grayscale hover:grayscale-0 transition-all duration-500">
                        <div>
                            <h3 class="font-black text-sm uppercase truncate">${song.title}</h3>
                            <p class="text-xs text-gray-400">${song.author.name}</p>
                        </div>
                    </div>
                `;
                grid.innerHTML += card;
            });
        }

        function playMusic(id, title, artist, thumb) {
            const playerBar = document.getElementById('player-bar');
            const iframe = document.getElementById('main-player');
            const titleDisplay = document.getElementById('player-title');
            const artistDisplay = document.getElementById('player-artist');
            const thumbDisplay = document.getElementById('player-thumb');
            
            iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&modestbranding=1`;
            titleDisplay.innerText = title.toUpperCase();
            artistDisplay.innerText = artist;
            thumbDisplay.src = thumb;
            
            playerBar.classList.remove('hidden');
        }

        function closePlayer() {
            const playerBar = document.getElementById('player-bar');
            document.getElementById('main-player').src = "";
            playerBar.classList.add('hidden');
        }

        // Search on Enter
        document.getElementById('searchInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') performSearch();
        });
    </script>
</body>
</html>
